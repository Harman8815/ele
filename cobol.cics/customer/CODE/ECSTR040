       IDENTIFICATION DIVISION.
       PROGRAM-ID. ECSTR040.

       ENVIRONMENT DIVISION.

       DATA DIVISION.

       WORKING-STORAGE SECTION.

           COPY DFHBMSCA.
           COPY DFHAID.
           COPY EB04MSD.

       01 WS-CICS-RESPONSE-CODES.
          05 DFHRESP-NORMAL        PIC S9(08) COMP VALUE 0.
          05 DFHRESP-NOTFND        PIC S9(08) COMP VALUE +13.
          05 DFHRESP-LENGERR       PIC S9(08) COMP VALUE +16.
          05 DFHRESP-IOERR         PIC S9(08) COMP VALUE +18.
          05 DFHRESP-NOTOPEN       PIC S9(08) COMP VALUE +19.
          05 DFHRESP-ENOTFND       PIC S9(08) COMP VALUE +20.
          05 DFHRESP-ILLLOG        PIC S9(08) COMP VALUE +28.
          05 DFHRESP-TERMERR       PIC S9(08) COMP VALUE +32.
          05 DFHRESP-DUPKEY        PIC S9(08) COMP VALUE +33.
          05 DFHRESP-DUPREC        PIC S9(08) COMP VALUE +34.
       01 WS-COMMAREA.
          05 WS-DUMMY              PIC X(01).

       77 WS-RESP-CODE             PIC S9(08) COMP.
       77 WS-RESP-DISPLAY-CODE    PIC 9(08) DISPLAY.
       77 ERROR-FLAG              PIC 9(01) VALUE 0.

       01 WS-MSG                  PIC X(40).

       01 WS-CUST-ID               PIC X(12).

       01 WS-CUST-REC.
          05 CUST-ID               PIC X(12).
          05 FIRST-NAME            PIC X(10).
          05 LAST-NAME             PIC X(10).
          05 AREA-CODE             PIC X(6).
          05 OUT-SPACE             PIC X.
          05 ADDRESS-1             PIC X(29).
          05 CITY                  PIC X(10).
          05 UNITS                 PIC 9(05).


       LINKAGE SECTION.

       01 DFHCOMMAREA.
          05 LK-COMM-DATA          PIC X(01).

       PROCEDURE DIVISION.

       1000-MAIN-LOGIC.

           IF EIBCALEN = 0
               PERFORM 2000-INITIAL-SCREEN
           ELSE
               PERFORM 3000-RECEIVE-MAP
           END-IF.
           EXIT.
       2000-INITIAL-SCREEN.

           MOVE LOW-VALUES TO EB04MAPO
           MOVE -1 TO CIDL
           MOVE SPACES TO MSGTXTO.
           PERFORM 4000-SEND-MAP.
           EXIT.

       3000-RECEIVE-MAP.

           EXEC CICS RECEIVE
                MAP('EB04MAP')
                MAPSET('EB04MSD')
                INTO(EB04MAPI)
                RESP(WS-RESP-CODE)
           END-EXEC.
           EVALUATE WS-RESP-CODE
               WHEN DFHRESP-NORMAL
                   PERFORM 3100-EVAL-USER-RESP
               WHEN DFHRESP-LENGERR
                   MOVE 'RECEIVE DATA TOO LONG' TO MSGTXTO
                   PERFORM 4000-SEND-MAP
               WHEN DFHRESP-TERMERR
                   MOVE 'TERMINAL ERROR - TRY AGAIN' TO MSGTXTO
                   PERFORM 4000-SEND-MAP
               WHEN DFHRESP-ILLLOG
                   MOVE 'INVALID RECEIVE LOGIC' TO MSGTXTO
                   PERFORM 4000-SEND-MAP
               WHEN OTHER
                   MOVE WS-RESP-CODE TO WS-RESP-DISPLAY-CODE
                   STRING 'RECEIVE ERROR - CODE: ' DELIMITED BY SIZE
                           WS-RESP-DISPLAY-CODE DELIMITED BY SIZE
                          INTO MSGTXTO
                   PERFORM 4000-SEND-MAP
           END-EVALUATE.
           EXIT.

       3100-EVAL-USER-RESP.

           EVALUATE EIBAID
               WHEN DFHENTER
                    PERFORM 3200-PROCESS-INPUT
               WHEN DFHPF3
                    PERFORM 9000-TERMINATE
               WHEN DFHPF6
                    MOVE LOW-VALUES TO EB04MAPO
                    PERFORM 4000-SEND-MAP
               WHEN OTHER
                    MOVE 'INVALID KEY PRESSED' TO MSGTXTO
                    PERFORM 4000-SEND-MAP
           END-EVALUATE.
           EXIT.

       3200-PROCESS-INPUT.

      *----------------------------------------------------------------*
      * VALIDATION
      *----------------------------------------------------------------*
           MOVE SPACES TO MSGTXTO.
           MOVE 0 TO ERROR-FLAG.
           MOVE CIDI TO WS-CUST-ID
           IF CIDI IS EQUAL TO LOW-VALUES OR
              CIDI IS EQUAL TO SPACES
              MOVE 'CUSTOMER ID IS REQUIRED' TO MSGTXTO
              MOVE -1 TO CIDL
              MOVE 1 TO ERROR-FLAG
           END-IF.
           IF ERROR-FLAG = 1
              PERFORM 4000-SEND-MAP
           ELSE
               PERFORM 5000-READ-VSAM
           END-IF.

           EXIT.
       5000-READ-VSAM.
           MOVE CIDI TO WS-CUST-ID
           EXEC CICS READ
                DATASET('CU01KSDS')
                RIDFLD(WS-CUST-ID)
                INTO(WS-CUST-REC)
                RESP(WS-RESP-CODE)
           END-EXEC.
           EVALUATE WS-RESP-CODE
               WHEN DFHRESP-NORMAL
                   MOVE FIRST-NAME TO FNO
                   MOVE LAST-NAME  TO LNO
                   MOVE AREA-CODE  TO AREAO
                   MOVE ADDRESS-1  TO ADDRO
                   MOVE CITY       TO CITYO
                   MOVE UNITS      TO UNITO
                   MOVE 'CUSTOMER RECORD FOUND' TO MSGTXTO
               WHEN DFHRESP-NOTFND
                   MOVE 'CUSTOMER NOT FOUND' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN DFHRESP-LENGERR
                   MOVE 'RECORD LENGTH ERROR - CHECK DATASET' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN DFHRESP-IOERR
                   MOVE 'I/O ERROR - TRY AGAIN LATER' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN DFHRESP-NOTOPEN
                   MOVE 'DATASET NOT OPEN - CONTACT ADMIN' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN DFHRESP-ENOTFND
                   MOVE 'DATASET NOT FOUND - CHECK NAME' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN DFHRESP-ILLLOG
                   MOVE 'INVALID LOGIC ERROR - CONTACT ADMIN' TO MSGTXTO
                   MOVE -1 TO CIDL
               WHEN OTHER
                   MOVE WS-RESP-CODE TO WS-RESP-DISPLAY-CODE
                   STRING 'READ ERROR - CODE: ' DELIMITED BY SIZE
                           WS-RESP-DISPLAY-CODE DELIMITED BY SIZE
                          INTO MSGTXTO
                   MOVE -1 TO CIDL
           END-EVALUATE.

           PERFORM 4000-SEND-MAP.
           EXIT.
       4000-SEND-MAP.

           EXEC CICS SEND
                MAP('EB04MAP')
                MAPSET('EB04MSD')
                FROM(EB04MAPO)
                RESP(WS-RESP-CODE)
                ERASE
                CURSOR
           END-EXEC.
           EVALUATE WS-RESP-CODE
               WHEN DFHRESP-NORMAL
                  EXEC CICS RETURN
                       TRANSID('EB04')
                       COMMAREA(WS-COMMAREA)
                       LENGTH(LENGTH OF WS-COMMAREA)
                  END-EXEC
               WHEN DFHRESP-LENGERR
                   MOVE 'MAP DATA TOO LONG' TO MSGTXTO
               WHEN DFHRESP-TERMERR
                   MOVE 'TERMINAL ERROR - TRY AGAIN' TO MSGTXTO
               WHEN DFHRESP-ILLLOG
                   MOVE 'INVALID SEND LOGIC' TO MSGTXTO
               WHEN OTHER
                   MOVE WS-RESP-CODE TO WS-RESP-DISPLAY-CODE
                   STRING 'SEND ERROR - CODE: ' DELIMITED BY SIZE
                           WS-RESP-DISPLAY-CODE DELIMITED BY SIZE
                          INTO MSGTXTO
           END-EVALUATE.

           EXIT.
       9000-TERMINATE.
           MOVE 'PRESS CTRL + BREAK TO EXIT' TO WS-MSG.
           EXEC CICS SEND TEXT
                           FROM(WS-MSG)
                           RESP(WS-RESP-CODE)
                           ERASE
           END-EXEC.
           EVALUATE WS-RESP-CODE
               WHEN DFHRESP-NORMAL
                   EXEC CICS RETURN END-EXEC
               WHEN OTHER
                   MOVE WS-RESP-CODE TO WS-RESP-DISPLAY-CODE
                   STRING 'SEND TEXT ERROR - CODE: ' DELIMITED BY SIZE
                           WS-RESP-DISPLAY-CODE DELIMITED BY SIZE
                          INTO MSGTXTO
                   EXEC CICS RETURN END-EXEC
           END-EVALUATE.

